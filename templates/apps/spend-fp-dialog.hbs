<div class='spend-fp-dialog flexcol'>
  <header style='margin-bottom:8px;'>
    <h2 style='margin:0 0 4px;'>{{actor.name}} — Spend Free Points</h2>
    <p class='hint' style='font-size:11px;color:#888;margin:0;'>
      Allocate any portion of your free-point pool to ability scores. Unspent points stay in the pool for later.
    </p>
  </header>

  <div class='free-points-summary flexrow'>
    <span>Pool: <strong>{{pool}}</strong></span>
    <span>Allocated: <strong>{{allocated}}</strong></span>
    <span>Remaining: <strong style='color:{{#if overspent}}#c33{{else}}#3a5{{/if}};'>{{remaining}}</strong></span>
  </div>

  <div class='stat-gains-table'>
    <div class='gains-header flexrow'>
      <span class='gains-col-name'>Ability</span>
      <span class='gains-col'>Current</span>
      <span class='gains-col'>Spend</span>
      <span class='gains-col'>After</span>
    </div>
    {{#each abilities as |a|}}
      <div class='gains-row flexrow'>
        <span class='gains-col-name' style='text-transform:capitalize;'>{{a.key}}</span>
        <span class='gains-col'>{{a.current}}</span>
        <span class='gains-col free-point-group'>
          <button type='button' class='free-point-dec' data-ability='{{a.key}}' {{#unless a.alloc}}disabled{{/unless}}>−</button>
          <input type='number' class='free-point-input' data-ability='{{a.key}}'
                 value='{{a.alloc}}' min='0' />
          {{#if @root.remaining}}
            <button type='button' class='free-point-inc' data-ability='{{a.key}}'>+</button>
          {{/if}}
        </span>
        <span class='gains-col gains-total'>{{a.after}}</span>
      </div>
    {{/each}}
  </div>

  {{#if overspent}}
    <p class='warning' style='color:#c33;margin-top:8px;'>You've allocated more than your available pool — reduce some inputs.</p>
  {{/if}}

  <footer class='level-up-actions flexrow'>
    <button type='button' data-action='cancel'>Cancel</button>
    <button type='button' data-action='apply' {{#unless canApply}}disabled{{/unless}}>Apply</button>
  </footer>
</div>
