<form class="{{cssClass}} {{actor.type}} flexcol" autocomplete="off">

  {{!-- Sheet Header --}}
  <header class="sheet-header">
    <div class="profile-img-group">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" height="100" width="100"/>
      <div class="wounded-img-picker" title="Wounded token image (swaps at low HP)">
        <img class="wounded-img {{#unless system.tokenImageWounded}}placeholder{{/unless}}"
             src="{{#if system.tokenImageWounded}}{{system.tokenImageWounded}}{{else}}icons/svg/blood.svg{{/if}}"
             data-field="system.tokenImageWounded" width="32" height="32"/>
      </div>
      <div class="progress-btn-picker" title="Progress Roll">
        <i class="fas fa-dice-d20 progress-roll-btn"></i>
      </div>
    </div>
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{actor.name}}" placeholder="Name"/></h1>

      {{!-- ── Resource Bars ── --}}
      <div class="resource-bars">
        <div class="resource-bar-row resource-health" data-tooltip="{{{tooltips.hp}}}">
          <label class="bar-label">HP</label>
          <div class="bar-track">
            <div class="bar-fill bar-fill-health" style="width: {{#if (gt system.health.max 0)}}{{math system.health.value '/' system.health.max '*' 100}}{{else}}0{{/if}}%"></div>
          </div>
          <div class="bar-values">
            <input type="number" name="system.health.value" value="{{system.health.value}}" min="0"/>
            <span class="bar-separator">/</span>
            <span class="bar-max">{{system.health.max}}</span>
          </div>
        </div>

        <div class="resource-bar-row resource-mana" data-tooltip="{{{tooltips.mana}}}">
          <label class="bar-label">MP</label>
          <div class="bar-track">
            <div class="bar-fill bar-fill-mana" style="width: {{#if (gt system.mana.max 0)}}{{math system.mana.value '/' system.mana.max '*' 100}}{{else}}0{{/if}}%"></div>
          </div>
          <div class="bar-values">
            <input type="number" name="system.mana.value" value="{{system.mana.value}}" min="0"/>
            <span class="bar-separator">/</span>
            <span class="bar-max">{{system.mana.max}}</span>
          </div>
        </div>

        <div class="resource-bar-row resource-stamina" data-tooltip="{{{tooltips.stamina}}}">
          <label class="bar-label">SP</label>
          <div class="bar-track">
            <div class="bar-fill bar-fill-stamina" style="width: {{#if (gt system.stamina.max 0)}}{{math system.stamina.value '/' system.stamina.max '*' 100}}{{else}}0{{/if}}%"></div>
          </div>
          <div class="bar-values">
            <input type="number" name="system.stamina.value" value="{{system.stamina.value}}" min="0"/>
            <span class="bar-separator">/</span>
            <span class="bar-max">{{system.stamina.max}}</span>
          </div>
        </div>

        {{!-- Overhealth — always present, dims when empty --}}
        <div class="resource-bar-row resource-overhealth {{#unless (gt system.overhealth.value 0)}}bar-empty{{/unless}}">
          <label class="bar-label">OH</label>
          <div class="bar-track">
            <div class="bar-fill bar-fill-overhealth" style="width: {{#if (gt system.overhealth.cap 0)}}{{math system.overhealth.value '/' system.overhealth.cap '*' 100}}{{else}}0{{/if}}%"></div>
          </div>
          <div class="bar-values">
            <span>{{system.overhealth.value}}</span>
            <span class="bar-separator">/</span>
            <span class="bar-max">{{system.overhealth.cap}}</span>
            {{#if (gt system.overhealth.value 0)}}
              <a class="clear-overhealth" title="Remove Overhealth"><i class="fas fa-times-circle"></i></a>
            {{/if}}
          </div>
        </div>

        {{!-- Barrier — always present, dims when empty --}}
        <div class="resource-bar-row resource-barrier {{#unless (gt system.barrier.max 0)}}bar-empty{{/unless}}">
          <label class="bar-label">BR</label>
          <div class="bar-track">
            <div class="bar-fill bar-fill-barrier" style="width: {{#if (gt system.barrier.max 0)}}{{math system.barrier.value '/' system.barrier.max '*' 100}}{{else}}0{{/if}}%"></div>
          </div>
          <div class="bar-values">
            <span>{{system.barrier.value}}</span>
            <span class="bar-separator">/</span>
            <span class="bar-max">{{system.barrier.max}}</span>
            {{#if system.barrier.affinities.length}}
              {{#each system.barrier.affinities as |aff|}}
                <span class="affinity-chip">{{aff}}</span>
              {{/each}}
            {{/if}}
            {{#if (gt system.barrier.max 0)}}
              <a class="clear-barrier" title="Remove Barrier"><i class="fas fa-times-circle"></i></a>
            {{/if}}
          </div>
        </div>
      </div>

      {{!-- ── Defenses + Identity side by side ── --}}
      <div class="header-bottom">
        <div class="defense-block">
          <div class="defense-row defense-mitigation">
            <div class="defense-item" data-tooltip="{{{tooltips.dr}}}">
              <label>DR</label>
              <span>{{system.defense.dr.value}}</span>
            </div>
            <div class="defense-item" data-tooltip="{{{tooltips.armor}}}">
              <label>Armor</label>
              <span>{{system.defense.armor.value}}</span>
            </div>
            <div class="defense-item" data-tooltip="{{{tooltips.veil}}}">
              <label>Veil</label>
              <span>{{system.defense.veil.value}}</span>
            </div>
          </div>
          <div class="defense-row defense-pools">
            <div class="defense-item" data-tooltip="{{{tooltips.melee}}}">
              <label>Melee</label>
              <span>{{system.defense.melee.pool}}/{{system.defense.melee.poolMax}}</span>
            </div>
            <div class="defense-item" data-tooltip="{{{tooltips.ranged}}}">
              <label>Ranged</label>
              <span>{{system.defense.ranged.pool}}/{{system.defense.ranged.poolMax}}</span>
            </div>
            <div class="defense-item" data-tooltip="{{{tooltips.mind}}}">
              <label>Mind</label>
              <span>{{system.defense.mind.pool}}/{{system.defense.mind.poolMax}}</span>
            </div>
            <div class="defense-item" data-tooltip="{{{tooltips.soul}}}">
              <label>Soul</label>
              <span>{{system.defense.soul.pool}}/{{system.defense.soul.poolMax}}</span>
            </div>
          </div>
        </div>

        <div class="identity-block">
          <div class="identity-row">
            <label>Class</label>
            <input type="number" name="system.attributes.class.level" value="{{system.attributes.class.level}}" min="0" class="identity-level"/>
            <span class="template-name">
              {{#if templateRefs.class.hasTemplate}}
                <a class="template-link" data-template-id="{{templateRefs.class.templateId}}">{{templateRefs.class.templateName}}</a>
                {{#if isGM}}<a class="template-clear" data-type="class" title="Clear"><i class="fas fa-times"></i></a>{{/if}}
              {{else}}
                <em>{{system.attributes.class.name}}</em>
              {{/if}}
            </span>
            <span class="identity-rank">{{system.attributes.class.rank}}</span>
          </div>
          <div class="identity-row">
            <label>Race</label>
            <input type="number" name="system.attributes.race.level" value="{{system.attributes.race.level}}" min="0" class="identity-level"/>
            <span class="template-name">
              {{#if templateRefs.race.hasTemplate}}
                <a class="template-link" data-template-id="{{templateRefs.race.templateId}}">{{templateRefs.race.templateName}}</a>
                {{#if isGM}}<a class="template-clear" data-type="race" title="Clear"><i class="fas fa-times"></i></a>{{/if}}
              {{else}}
                <em>{{system.attributes.race.name}}</em>
              {{/if}}
            </span>
            <span class="identity-rank">{{system.attributes.race.rank}}</span>
          </div>
          <div class="identity-row">
            <label>Prof</label>
            <input type="number" name="system.attributes.profession.level" value="{{system.attributes.profession.level}}" min="0" class="identity-level"/>
            <span class="template-name">
              {{#if templateRefs.profession.hasTemplate}}
                <a class="template-link" data-template-id="{{templateRefs.profession.templateId}}">{{templateRefs.profession.templateName}}</a>
                {{#if isGM}}<a class="template-clear" data-type="profession" title="Clear"><i class="fas fa-times"></i></a>{{/if}}
              {{else}}
                <em>{{system.attributes.profession.name}}</em>
              {{/if}}
            </span>
            <span class="identity-rank">{{system.attributes.profession.rank}}</span>
          </div>
          <div class="identity-row identity-actions">
            <button type="button" class="level-up-btn">
              <i class="fas fa-arrow-up"></i> {{localize "ASPECTSOFPOWER.Level.levelUp"}}
            </button>
            {{#if (gt freePoints 0)}}
              <span class="free-points-badge">{{localize "ASPECTSOFPOWER.Level.freePoints"}}: {{freePoints}}</span>
            {{/if}}
          </div>
        </div>
      </div>
    </div>
  </header>

  {{!-- Sheet Tab Navigation --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="features">Features</a>
    <a class="item" data-tab="skills">Skills</a>
    <a class="item" data-tab="stats">Stats</a>
    <a class="item" data-tab="equipment">{{localize "ASPECTSOFPOWER.Equip.tabLabel"}}</a>
    <a class="item" data-tab="items">Items</a>
    <a class="item" data-tab="effects">Effects</a>
    <a class="item" data-tab="description">Description</a>
  </nav>

  {{!-- Sheet Body --}}
  <section class="sheet-body scrollable" data-scrollable>

    {{!-- Owned Features Tab --}}
    <div class="tab features" data-group="primary" data-tab="features">
      <section class="grid grid-3col">
        <aside class="sidebar">

          <div class="abilities flexcol">
            {{#each system.abilities as |ability key|}}
            <div class="ability flexrow flex-group-center" data-tooltip="{{{lookup @root.tooltips.abilities key}}}">
              <label for="system.abilities.{{key}}.value" class="resource-label rollable flexlarge align-left" data-roll="(d20/100)*@abilities.{{key}}.mod+@abilities.{{key}}.mod" data-label="{{localize (lookup @root.config.abilities key)}}">{{localize (lookup @root.config.abilities key)}}</label>
              <input type="number" name="system.abilities.{{key}}.value" value="{{ability.value}}" min="0"/>
              <span class="stat-mod rollable" data-roll="(d20/100)*@abilities.{{key}}.mod+@abilities.{{key}}.mod" data-label="{{localize (lookup @root.config.abilities key)}}">{{numberFormat ability.mod decimals=0 sign=true}}</span>
            </div>
            {{/each}}
          </div>
        </aside>

        <section class="main grid-span-2">
          {{#each skillGroups as |group groupKey|}}
            {{#if (or group.active.length group.reactions.length)}}
            <details class="skill-group" open>
              <summary class="skill-group-header">
                <span class="skill-group-label">{{group.label}}</span>
                <span class="skill-group-count">({{math group.active.length '+' group.reactions.length}})</span>
              </summary>
              <ol class='items-list'>
                {{#each group.active as |item|}}
                  <li class='item flexrow' data-item-id='{{item._id}}'>
                    <div class='item-name flexrow'>
                      <div class='item-image'>
                        <a class='rollable' data-roll-type='item'><img src='{{item.img}}' title='{{item.name}}' width='20' height='20' /></a>
                      </div>
                      <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
                    </div>
                    <div class='item-controls'>
                      <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
                      <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
                    </div>
                  </li>
                {{/each}}
                {{#if group.reactions.length}}
                  <li class='item flexrow skill-reactions-header'>
                    <div class='item-name'><i class='fas fa-bolt'></i> Reactions</div>
                  </li>
                  {{#each group.reactions as |item|}}
                    <li class='item flexrow skill-reaction' data-item-id='{{item._id}}'>
                      <div class='item-name flexrow'>
                        <div class='item-image'>
                          <a class='rollable' data-roll-type='item'><img src='{{item.img}}' title='{{item.name}}' width='20' height='20' /></a>
                        </div>
                        <h4 style="color: {{item.rarityColor}}"><i class='fas fa-bolt' style='font-size:10px;opacity:0.6;margin-right:4px;'></i>{{item.name}}</h4>
                      </div>
                      <div class='item-controls'>
                        <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
                        <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
                      </div>
                    </li>
                  {{/each}}
                {{/if}}
              </ol>
            </details>
            {{/if}}
          {{/each}}
        </section>

      </section>
    </div>

    {{!-- Stats Tab --}}
    <div class="tab stats" data-group="primary" data-tab="stats">
      <div class="stats-breakdown">

        {{!-- Summary --}}
        <div class="stats-summary flexrow">
          <span>{{localize "ASPECTSOFPOWER.Stats.totalCalculated"}}: {{statsSummary.totalCalculated}}</span>
          <span>{{localize "ASPECTSOFPOWER.Stats.globalEquipCap"}}: {{statsSummary.globalCap}}</span>
          <span>{{localize "ASPECTSOFPOWER.Stats.equipmentUsed"}}: {{statsSummary.totalEquipCapped}} / {{statsSummary.totalEquipRaw}}</span>
        </div>

        {{!-- Column headers --}}
        <div class="stat-header flexrow">
          <span class="stat-col-name">{{localize "ASPECTSOFPOWER.AttributeGroup.abilities"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.base"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.calculated"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.equipmentBonus"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.equipmentCap"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.effectBonus"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.withEquipment"}}</span>
          <span class="stat-col">{{localize "ASPECTSOFPOWER.Stats.finalMod"}}</span>
        </div>

        {{!-- One row per ability --}}
        <div class="stat-list">
          {{#each system.abilities as |ability key|}}
          <div class="stat-row flexrow">
            <label class="stat-col-name rollable"
                   data-roll="(d20/100)*@abilities.{{key}}.mod+@abilities.{{key}}.mod"
                   data-label="{{localize (lookup @root.config.abilities key)}}">
              {{localize (lookup @root.config.abilities key)}}
            </label>
            <span class="stat-col">
              <input type="number" name="system.abilities.{{key}}.value"
                     value="{{ability.breakdown.base}}" min="0" class="stat-input"/>
            </span>
            <span class="stat-col">{{ability.breakdown.calculated}}</span>
            {{#if (gt ability.breakdown.equipmentBonusRaw ability.breakdown.equipmentCapped)}}
              <span class="stat-col capped">
                {{ability.breakdown.equipmentCapped}}
                <span class="raw-value">({{ability.breakdown.equipmentBonusRaw}})</span>
              </span>
            {{else}}
              <span class="stat-col">{{ability.breakdown.equipmentCapped}}</span>
            {{/if}}
            <span class="stat-col">{{ability.breakdown.perStatCap}}</span>
            <span class="stat-col">{{ability.breakdown.effectBonus}}</span>
            <span class="stat-col stat-total"><strong>{{ability.breakdown.final}}</strong></span>
            <span class="stat-col stat-mod rollable"
                  data-roll="(d20/100)*@abilities.{{key}}.mod+@abilities.{{key}}.mod"
                  data-label="{{localize (lookup @root.config.abilities key)}}">
              {{numberFormat ability.breakdown.finalMod decimals=0 sign=true}}
            </span>
          </div>
          {{/each}}
        </div>

        {{!-- Ranges --}}
        <div class="stats-ranges flexrow">
          <span class="range-item">
            <strong>{{localize "ASPECTSOFPOWER.Range.castingRange"}}:</strong> {{system.castingRange}} ft
          </span>
          <span class="range-item">
            <strong>{{localize "ASPECTSOFPOWER.Range.walkRange"}}:</strong> {{system.walkRange}} ft
          </span>
          <span class="range-item">
            <strong>{{localize "ASPECTSOFPOWER.Range.sprintRange"}}:</strong> {{system.sprintRange}} ft
          </span>
        </div>

      </div>
    </div>

    {{!-- Equipment Tab --}}
    <div class="tab equipment" data-group="primary" data-tab="equipment">
      <div class="equipment-tab">

        {{!-- Carrying Capacity + Credits --}}
        <div class="carry-summary flexrow">
          <span class="carry-label">
            <strong>{{localize "ASPECTSOFPOWER.Equip.carryCapacity"}}:</strong>
            {{system.carryWeight}} / {{system.carryCapacity}}
            {{#if system.encumbered}}
              <span class="encumbered-warn">{{localize "ASPECTSOFPOWER.Equip.encumbered"}}</span>
            {{/if}}
          </span>
          <div class="carry-bar-outer">
            <div class="carry-bar-inner {{#if system.encumbered}}over-capacity{{/if}}"
                 style="width: {{carryPercent}}%"></div>
          </div>
          <span class="credits-label">
            <i class="fas fa-coins" style="color:#ffc107;"></i>
            <strong>Credits:</strong>
            <input type="number" name="system.credits" value="{{system.credits}}" min="0" style="width:80px;" />
          </span>
        </div>

        {{!-- Gear Set Toggle --}}
        <div class="gear-set-toggle flexrow">
          <a class="gear-toggle-btn active" data-set="combat"><i class="fas fa-shield-alt"></i> Combat</a>
          <a class="gear-toggle-btn" data-set="profession"><i class="fas fa-hammer"></i> Profession</a>
        </div>

        {{!-- Combat Equipment Slots --}}
        <div class="equip-slots gear-set gear-set-combat">
          {{#each combatSlots as |slotData slotKey|}}
            <div class="slot-group">
              <div class="slot-header flexrow">
                <strong>{{slotData.label}}</strong>
                <span class="slot-count">({{slotData.items.length}} / {{slotData.max}})</span>
              </div>
              {{#if slotData.items.length}}
                {{#each slotData.items as |item|}}
                  <div class="item equipped-item flexrow" data-item-id="{{item._id}}">
                    <div class="item-image">
                      <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
                    </div>
                    <span class="item-name">
                      <h4 class="equip-item-name" style="color: {{item.rarityColor}}">{{item.name}}</h4>
                    </span>
                    <span class="durability-display">
                      <span class="durability-bar-outer">
                        <span class="durability-bar-inner" style="width: {{item.durabilityPercent}}%"></span>
                      </span>
                      <span class="durability-text">{{item.system.durability.value}}/{{item.system.durability.max}}</span>
                    </span>
                    <div class="item-controls">
                      {{#if (lt item.system.durability.value item.system.durability.max)}}
                        <a class="repair-item" title="{{localize 'ASPECTSOFPOWER.Equip.repair'}}"><i class="fas fa-wrench"></i></a>
                      {{/if}}
                      <a class="equip-toggle" title="{{localize 'ASPECTSOFPOWER.Equip.unequip'}}"><i class="fas fa-shield-alt"></i></a>
                      <a class="item-edit" title="{{localize 'DOCUMENT.Update' type='Item'}}"><i class="fas fa-edit"></i></a>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <div class="slot-empty">—</div>
              {{/if}}
            </div>
          {{/each}}
        </div>

        {{!-- Profession Equipment Slots --}}
        <div class="equip-slots gear-set gear-set-profession" style="display:none;">
          {{#each professionSlots as |slotData slotKey|}}
            <div class="slot-group">
              <div class="slot-header flexrow">
                <strong>{{slotData.label}}</strong>
                <span class="slot-count">({{slotData.items.length}} / {{slotData.max}})</span>
              </div>
              {{#if slotData.items.length}}
                {{#each slotData.items as |item|}}
                  <div class="item equipped-item flexrow" data-item-id="{{item._id}}">
                    <div class="item-image">
                      <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
                    </div>
                    <span class="item-name">
                      <h4 class="equip-item-name" style="color: {{item.rarityColor}}">{{item.name}}</h4>
                    </span>
                    <span class="durability-display">
                      <span class="durability-bar-outer">
                        <span class="durability-bar-inner" style="width: {{item.durabilityPercent}}%"></span>
                      </span>
                      <span class="durability-text">{{item.system.durability.value}}/{{item.system.durability.max}}</span>
                    </span>
                    <div class="item-controls">
                      {{#if (lt item.system.durability.value item.system.durability.max)}}
                        <a class="repair-item" title="{{localize 'ASPECTSOFPOWER.Equip.repair'}}"><i class="fas fa-wrench"></i></a>
                      {{/if}}
                      <a class="equip-toggle" title="{{localize 'ASPECTSOFPOWER.Equip.unequip'}}"><i class="fas fa-shield-alt"></i></a>
                      <a class="item-edit" title="{{localize 'DOCUMENT.Update' type='Item'}}"><i class="fas fa-edit"></i></a>
                    </div>
                  </div>
                {{/each}}
              {{else}}
                <div class="slot-empty">—</div>
              {{/if}}
            </div>
          {{/each}}
        </div>

        {{!-- Unequipped Inventory --}}
        <div class="unequipped-section">
          <div class="items-header flexrow">
            <span class="item-name">{{localize "ASPECTSOFPOWER.Equip.unequipped"}}</span>
            <span class="item-prop equip-col-weight">{{localize "ASPECTSOFPOWER.Equip.weight"}}</span>
            <span class="item-prop equip-col-qty">{{localize "ASPECTSOFPOWER.Equip.quantity"}}</span>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'DOCUMENT.Create' type='Item'}}" data-type="item">
                <i class="fas fa-plus"></i> {{localize "DOCUMENT.New" type="item"}}
              </a>
            </div>
          </div>
          {{#each unequippedGear as |item|}}
            <div class="item unequipped-item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
                </div>
                <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
              </div>
              <span class="item-prop equip-col-weight">{{item.system.weight}}</span>
              <span class="item-prop equip-col-qty">{{item.system.quantity}}</span>
              <div class="item-controls">
                {{#if item.system.slot}}
                  <a class="equip-toggle" title="{{localize 'ASPECTSOFPOWER.Equip.equip'}}">
                    <i class="fas fa-arrow-up"></i>
                  </a>
                {{/if}}
                <a class="item-trade" title="Trade / Give"><i class="fas fa-handshake"></i></a>
                <a class="item-edit" title="{{localize 'DOCUMENT.Update' type='Item'}}">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="item-delete" title="{{localize 'DOCUMENT.Delete' type='Item'}}">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
            </div>
          {{/each}}
        </div>

        {{!-- Consumables --}}
        <div class="consumables-section">
          <div class="items-header flexrow">
            <span class="item-name">{{localize "ASPECTSOFPOWER.Consumable.sectionTitle"}}</span>
            <span class="item-prop consumable-col-type">{{localize "ASPECTSOFPOWER.Consumable.type"}}</span>
            <span class="item-prop consumable-col-effect">Effect</span>
            <span class="item-prop consumable-col-uses">Uses</span>
            <div class="item-controls">
              <a class="item-control item-create" title="{{localize 'DOCUMENT.Create' type='Item'}}" data-type="consumable">
                <i class="fas fa-plus"></i> New Consumable
              </a>
            </div>
          </div>
          {{#each consumables as |item|}}
            <div class="item consumable-item flexrow" data-item-id="{{item._id}}">
              <div class="item-name">
                <div class="item-image">
                  <img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
                </div>
                <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
              </div>
              <span class="item-prop consumable-col-type">{{item.consumableLabel}}</span>
              <span class="item-prop consumable-col-effect">{{item.effectSummary}}</span>
              <span class="item-prop consumable-col-uses">{{item.usesDisplay}}</span>
              <div class="item-controls">
                <a class="consumable-use" title="{{localize 'ASPECTSOFPOWER.Consumable.use'}}">
                  <i class="fas fa-flask"></i>
                </a>
                <a class="item-edit" title="{{localize 'DOCUMENT.Update' type='Item'}}">
                  <i class="fas fa-edit"></i>
                </a>
                <a class="item-delete" title="{{localize 'DOCUMENT.Delete' type='Item'}}">
                  <i class="fas fa-trash"></i>
                </a>
              </div>
            </div>
          {{/each}}
        </div>

      </div>
    </div>

    {{!-- Biography Tab --}}
    <div class="tab biography" data-group="primary" data-tab="description">
      <prose-mirror name="system.biography" value="{{system.biography}}" compact>
        {{{enrichedBiography}}}
      </prose-mirror>
    </div>

    {{!-- Owned Items Tab --}}
    <div class="tab items" data-group="primary" data-tab="items">
       {{> "systems/aspects-of-power/templates/actor/parts/actor-items.hbs"}}

    </div>

    {{!-- Owned Skills Tab --}}
    <div class="tab skills" data-group="primary" data-tab="skills">
      {{#each skillGroups as |group groupKey|}}
        {{#if (or group.active.length group.reactions.length)}}
        <details class="skill-group" open>
          <summary class="skill-group-header">
            <span class="skill-group-label">{{group.label}}</span>
            <span class="skill-group-count">({{math group.active.length '+' group.reactions.length}})</span>
            <a class='item-control item-create' title='Add Skill' data-type='skill' data-skill-category='{{groupKey}}'>
              <i class='fas fa-plus'></i>
            </a>
          </summary>
          <ol class='items-list'>
            {{#each group.active as |item|}}
              <li class='item flexrow' data-item-id='{{item._id}}'>
                <div class='item-name flexrow'>
                  <div class='item-image'>
                    <a class='rollable' data-roll-type='item'><img src='{{item.img}}' title='{{item.name}}' width='20' height='20' /></a>
                  </div>
                  <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
                </div>
                <div class='item-controls'>
                  <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
                  <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
                </div>
              </li>
            {{/each}}
            {{#if group.reactions.length}}
              <li class='item flexrow skill-reactions-header'>
                <div class='item-name'><i class='fas fa-bolt'></i> Reactions</div>
              </li>
              {{#each group.reactions as |item|}}
                <li class='item flexrow skill-reaction' data-item-id='{{item._id}}'>
                  <div class='item-name flexrow'>
                    <div class='item-image'>
                      <a class='rollable' data-roll-type='item'><img src='{{item.img}}' title='{{item.name}}' width='20' height='20' /></a>
                    </div>
                    <h4 style="color: {{item.rarityColor}}"><i class='fas fa-bolt' style='font-size:10px;opacity:0.6;margin-right:4px;'></i>{{item.name}}</h4>
                  </div>
                  <div class='item-controls'>
                    <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
                    <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
                  </div>
                </li>
              {{/each}}
            {{/if}}
          </ol>
        </details>
        {{/if}}
      {{/each}}
    </div>

    {{!-- Active Effects Tab --}}
    <div class="tab effects flexcol" data-group="primary" data-tab="effects">
      {{> "systems/aspects-of-power/templates/actor/parts/actor-effects.hbs"}}
    </div>

  </section>
</form>
