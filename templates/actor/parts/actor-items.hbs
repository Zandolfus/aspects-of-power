<div class="items-tab-content">

  {{!-- Items Section --}}
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>Items</div>
      <div class='item-controls'>
        <a class='item-control item-create' title='New Item' data-type='item'>
          <i class='fas fa-plus'></i> New Item
        </a>
      </div>
    </li>
    {{#each gear as |item id|}}
      <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class='item-name'>
          <div class='item-image'>
            <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
          </div>
          <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
        </div>
        <div class='item-controls'>
          <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
          <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
        </div>
      </li>
    {{/each}}
  </ol>

  {{!-- Consumables Section --}}
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize "ASPECTSOFPOWER.Consumable.sectionTitle"}}</div>
      <div class='item-controls'>
        <a class='item-control item-create' title='New Consumable' data-type='consumable'>
          <i class='fas fa-plus'></i> New Consumable
        </a>
      </div>
    </li>
    {{#each consumables as |item id|}}
      <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class='item-name'>
          <div class='item-image'>
            <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
          </div>
          <h4 style="color: {{item.rarityColor}}">{{item.name}}</h4>
        </div>
        <span class="item-prop">{{item.consumableLabel}}</span>
        <div class='item-controls'>
          <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
          <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
        </div>
      </li>
    {{/each}}
  </ol>

  {{!-- Features Section --}}
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>Features</div>
      <div class='item-controls'>
        <a class='item-control item-create' title='New Feature' data-type='feature'>
          <i class='fas fa-plus'></i> New Feature
        </a>
      </div>
    </li>
    {{#each features as |item id|}}
      <li class='item flexrow' data-item-id='{{item._id}}'>
        <div class='item-name'>
          <div class='item-image'>
            <img src='{{item.img}}' title='{{item.name}}' width='24' height='24' />
          </div>
          <h4>{{item.name}}</h4>
        </div>
        <div class='item-controls'>
          <a class='item-control item-edit' title='Edit'><i class='fas fa-edit'></i></a>
          <a class='item-control item-delete' title='Delete'><i class='fas fa-trash'></i></a>
        </div>
      </li>
    {{/each}}
  </ol>

</div>