<form class='{{cssClass}} flexcol' autocomplete='off'>
  <header class='sheet-header'>
    <img class='profile-img' src='{{item.img}}' data-edit='img' title='{{item.name}}' />
    <div class='header-fields'>
      <h1 class='charname'>
        <input name='name' type='text' value='{{item.name}}' placeholder='Name' />
        {{! Favorite toggle — surfaces in the combat quick-actions dialog. }}
        <label class='skill-favorite-toggle' title='Mark as favorite (shows in combat quick-actions dialog).'>
          <input type='checkbox' name='system.favorite' {{#if system.favorite}}checked{{/if}} />
          <i class='fa-star {{#if system.favorite}}fas{{else}}far{{/if}}'></i>
        </label>
        {{! Rarity chip — sits inline next to the name (matches the tag-chip pattern below). Drives the universal damage multiplier. }}
        <select name='system.rarity' class='skill-rarity-chip'
                title='{{localize "ASPECTSOFPOWER.SkillRarity.label"}}'
                style="color: {{lookup (lookup config.skillRarities system.rarity) 'color'}}; border-color: {{lookup (lookup config.skillRarities system.rarity) 'color'}};">
          {{#each config.skillRarities as |rarDef rarKey|}}
            <option value='{{rarKey}}' {{#if (eq rarKey @root.system.rarity)}}selected{{/if}}
                    style="color: {{rarDef.color}}">
              {{localize rarDef.label}} ({{rarDef.mult}})
            </option>
          {{/each}}
        </select>
        <button type='button' class='skill-upgrade-btn' title='Create a new linked higher-rarity version on the owning actor.' style='font-size:11px;padding:2px 8px;margin-left:6px;'>
          ⬆ Upgrade
        </button>
      </h1>

      {{! Tag chips + autocomplete (always visible) }}
      <div class='skill-tags'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.Tag.label"}}</label>
        <div class='skill-tag-chips'>
          {{#each system.tags as |tag|}}
            <span class='skill-tag-chip'>
              {{tag}}
              <a class='skill-tag-remove' data-tag='{{tag}}' title='Remove'>×</a>
            </span>
          {{/each}}
        </div>
        <div class='skill-tag-autocomplete'>
          <input type='text' class='skill-tag-input' placeholder='Type to search tags...' autocomplete='off' />
          <ul class='skill-tag-suggestions'></ul>
        </div>
      </div>
    </div>
  </header>

  {{! Sheet Tab Navigation }}
  <nav class='sheet-tabs tabs' data-group='primary'>
    <a class='item' data-tab='description'>Description</a>
    <a class='item' data-tab='effects'>Effects</a>
    <a class='item' data-tab='attributes'>Attributes</a>
  </nav>

  {{! Sheet Body }}
  <section class='sheet-body scrollable' data-scrollable>

    {{! Description Tab }}
    <div class='tab' data-group='primary' data-tab='description'>
      {{! ── Derived Stats Readout — live "show me the math" panel. Surfaced on Description so it's the first thing visible on open. ── }}
      {{#if derivedStats}}
      <div class='derived-stats' style='background:#1a1a1a;border:1px solid #444;border-radius:4px;padding:8px;margin-bottom:10px;font-size:11px;'>
        <div style='display:flex;flex-wrap:wrap;gap:12px;align-items:baseline;'>
          <div><strong>Rarity:</strong> {{localize derivedStats.rarityLabel}} <span style='color:#888;'>({{derivedStats.rarityMult}})</span></div>
          <div><strong>Effective Mult:</strong> <span style='color:#9cf;'>{{derivedStats.effectiveMult}}</span>
            <span style='color:#888;'>= {{derivedStats.rarityMult}}{{#if derivedStats.dmgSum}} + ({{derivedStats.dmgSum}}){{/if}} (floor 0)</span></div>
          <div><strong>Cost ×:</strong> <span style='color:#fc9;'>{{derivedStats.costMultiplier}}</span>
            <span style='color:#888;'>= 1{{#if derivedStats.costSum}} + ({{derivedStats.costSum}}){{/if}}</span></div>
          <div><strong>Weight ×:</strong> <span style='color:#cf9;'>{{derivedStats.effectiveWeightMultiplier}}</span>
            <span style='color:#888;'>= 1{{#if derivedStats.weightSum}} + ({{derivedStats.weightSum}}){{/if}}</span></div>
        </div>

        {{#if derivedStats.alterations.length}}
          <div style='margin-top:6px;color:#aaa;'>Alterations:
            {{#each derivedStats.alterations as |a|}}
              <span style='margin-right:8px;'>{{localize a.label}}<span style='color:#666;'> (dmg {{a.dmgMod}}, cost {{a.costMod}}, weight {{a.weightMod}})</span></span>
            {{/each}}
          </div>
        {{/if}}

        {{#if derivedStats.spellBaseManaScaled}}
          <div style='margin-top:6px;'>
            <strong>Spell base cost (5ft / 1×):</strong> <span style='color:#fc9;'>{{derivedStats.spellBaseManaScaled}}</span> mana
            <span style='color:#888;'>(tier × grade × cost mult)</span>
          </div>
        {{/if}}

        {{#if derivedStats.aoeCostScale}}
          <div style='margin-top:6px;'>
            <strong>AOE size cost ladder (2^n):</strong>
            {{#each derivedStats.aoeCostScale as |row|}}
              <span style='margin-right:10px;color:#aaa;'>{{row.ft}}ft = {{#if row.cost}}{{row.cost}}m{{else}}{{row.mult}}×{{/if}}</span>
            {{/each}}
          </div>
        {{/if}}
      </div>
      {{/if}}

      <prose-mirror name="system.description" value="{{system.description}}" compact>
        {{{enrichedDescription}}}
      </prose-mirror>
    </div>

    {{! Damage Tab }}
    <div class='tab effects' data-group='primary' data-tab='effects'>

      {{! ── Skill Category ── }}
      <div class='skill-category'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.SkillCategory.label"}}</label>
        <select name='system.skillCategory'>
          {{#each config.skillCategories as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.skillCategory)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
      </div>

      {{! ── AOE Config (driven by aoe tag) ── }}
      {{#if (includes system.tags "aoe")}}
      <div class='tag-config aoe-config'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.shape"}}</label>
        <select name='system.aoe.shape'>
          {{#each config.aoeShapes as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.aoe.shape)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>

        {{! Circle: diameter }}
        {{#if (eq system.aoe.shape "circle")}}
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.diameter"}}</label>
          <input type='number' name='system.aoe.diameter'
                 value='{{system.aoe.diameter}}' min='5' step='5' />
        {{/if}}

        {{! Cone: length + angle }}
        {{#if (eq system.aoe.shape "cone")}}
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.length"}}</label>
          <input type='number' name='system.aoe.diameter'
                 value='{{system.aoe.diameter}}' min='5' step='5' />
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.angle"}}</label>
          <input type='number' name='system.aoe.angle'
                 value='{{system.aoe.angle}}' min='1' max='360' step='1' />
        {{/if}}

        {{! Ray: length + width }}
        {{#if (eq system.aoe.shape "ray")}}
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.length"}}</label>
          <input type='number' name='system.aoe.diameter'
                 value='{{system.aoe.diameter}}' min='5' step='5' />
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.width"}}</label>
          <input type='number' name='system.aoe.width'
                 value='{{system.aoe.width}}' min='5' step='5' />
        {{/if}}

        {{! Rectangle (square): side length — Foundry rect is always a square }}
        {{#if (eq system.aoe.shape "rect")}}
          <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.size"}}</label>
          <input type='number' name='system.aoe.diameter'
                 value='{{system.aoe.diameter}}' min='5' step='5' />
        {{/if}}

        {{! Per-skill base size — sizes ≤ this cost the unmodified base mana; sizes above incur 2^n growth. Default 5 = no free area. }}
        <label class='resource-label' title='Sizes at-or-below this cost no extra mana; sizes above incur 2^n cost growth.'>Base Size (free) (ft)</label>
        <input type='number' name='system.aoe.baseSize'
               value='{{system.aoe.baseSize}}' min='5' step='5' />

        <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.targetingMode"}}</label>
        <select name='system.aoe.targetingMode'>
          {{#each config.aoeTargetingModes as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.aoe.targetingMode)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>

        <label class='resource-label'>{{localize "ASPECTSOFPOWER.AOE.templateDuration"}}</label>
        <input type='number' name='system.aoe.templateDuration'
               value='{{system.aoe.templateDuration}}' min='0' step='1' />
        <span class='hint'>{{localize "ASPECTSOFPOWER.AOE.templateDurationHint"}}</span>

        <label class='resource-label'>{{localize "ASPECTSOFPOWER.Zone.label"}}</label>
        <select name='system.aoe.zoneEffect'>
          {{#each config.zoneEffects as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.aoe.zoneEffect)}}selected{{/if}}>{{localize label}}</option>
          {{/each}}
        </select>

      </div>
      {{/if}}

      {{! ── Shared Roll Config — Ability/Dice/Cost are hidden for weapon-pillar types (str_weapon/dex_weapon/phys_ranged) since stat_blend × rarity × stamina-invest take over at roll time. Schema retains them for legacy fallback when no weapon is wielded. ── }}
      <div class='resource'>
        {{#if isWeaponPillarType}}
          <p class='hint' style='font-size:11px;color:#888;margin:0 0 6px;'>
            <em>Damage handled by the weapon/ranged pillar — stat blend from wielded weapon × rarity multiplier × stamina invest. Ability/Dice/Cost from the schema are only used as a legacy fallback when no weapon is wielded.</em>
          </p>
        {{/if}}
        <div class='grid {{#if isWeaponPillarType}}grid-2col{{else}}grid-5col{{/if}}'>
          {{#unless isWeaponPillarType}}
          <div class='grid-span-1'>
            <label class='resource-label'>{{#if (eq system.roll.statType "hybrid")}}Primary Ability{{else}}Ability{{/if}}</label>
            <select name='system.roll.abilities' data-dtype='String'>
              <option value="vitality" {{#if (eq system.roll.abilities "vitality")}}selected{{/if}}>Vitality</option>
              <option value="endurance" {{#if (eq system.roll.abilities "endurance")}}selected{{/if}}>Endurance</option>
              <option value="strength" {{#if (eq system.roll.abilities "strength")}}selected{{/if}}>Strength</option>
              <option value="dexterity" {{#if (eq system.roll.abilities "dexterity")}}selected{{/if}}>Dexterity</option>
              <option value="toughness" {{#if (eq system.roll.abilities "toughness")}}selected{{/if}}>Toughness</option>
              <option value="intelligence" {{#if (eq system.roll.abilities "intelligence")}}selected{{/if}}>Intelligence</option>
              <option value="willpower" {{#if (eq system.roll.abilities "willpower")}}selected{{/if}}>Willpower</option>
              <option value="wisdom" {{#if (eq system.roll.abilities "wisdom")}}selected{{/if}}>Wisdom</option>
              <option value="perception" {{#if (eq system.roll.abilities "perception")}}selected{{/if}}>Perception</option>
            </select>
          </div>
          <div class='grid-span-1'>
            <label class='resource-label'>Dice</label>
            <input type='text' name='system.roll.dice' value='{{system.roll.dice}}' data-dtype='String' />
          </div>
          {{/unless}}
          <div class='grid-span-1'>
            <label class='resource-label'>Resource</label>
            <select name='system.roll.resource'>
              {{#if availableResources}}
                {{#each availableResources as |label key|}}
                  <option value="{{key}}" {{#if (eq key ../system.roll.resource)}}selected{{/if}}>{{localize label}}</option>
                {{/each}}
              {{else}}
                <option value="mana" {{#if (eq system.roll.resource "mana")}}selected{{/if}}>Mana</option>
                <option value="stamina" {{#if (eq system.roll.resource "stamina")}}selected{{/if}}>Stamina</option>
                <option value="health" {{#if (eq system.roll.resource "health")}}selected{{/if}}>Health</option>
              {{/if}}
            </select>
          </div>
          {{#unless isWeaponPillarType}}
          <div class='grid-span-1'>
            <label class='resource-label'>Cost</label>
            <input type='number' name='system.roll.cost' value='{{system.roll.cost}}' min='0' step='1' />
          </div>
          {{/unless}}
          <div class='grid-span-1'>
            <label class='resource-label'>Skill Type</label>
            <select name='system.roll.type' data-dtype='String'>
              {{#if availableRollTypes}}
                {{#each availableRollTypes as |label key|}}
                  <option value="{{key}}" {{#if (eq key ../system.roll.type)}}selected{{/if}}>{{localize label}}</option>
                {{/each}}
              {{else}}
                <option value="str_weapon" {{#if (eq system.roll.type "str_weapon")}}selected{{/if}}>Strength Weapon</option>
                <option value="dex_weapon" {{#if (eq system.roll.type "dex_weapon")}}selected{{/if}}>Dexterity Weapon</option>
                <option value="phys_ranged" {{#if (eq system.roll.type "phys_ranged")}}selected{{/if}}>Physical Ranged</option>
                <option value="magic_projectile" {{#if (eq system.roll.type "magic_projectile")}}selected{{/if}}>Magic Projectile</option>
                <option value="magic_melee" {{#if (eq system.roll.type "magic_melee")}}selected{{/if}}>Magic Melee</option>
                <option value="wisdom_dexterity" {{#if (eq system.roll.type "wisdom_dexterity")}}selected{{/if}}>Wisdom/Dexterity</option>
              {{/if}}
            </select>
          </div>
        </div>

        {{! ── Spell Tier block — only for skills tagged 'magic'. Grade auto-derives from the wielder's race rank at cast time, so no grade dropdown here. ── }}
        {{#if (includes system.tags "magic")}}
        <div class='grid grid-3col spell-cost-block'>
          <div class='grid-span-1'>
            <label class='resource-label'>{{localize "ASPECTSOFPOWER.SpellTier.label"}}</label>
            <select name='system.roll.tier' data-dtype='String'>
              <option value='' {{#if (eq system.roll.tier "")}}selected{{/if}}>—</option>
              {{#each config.spellTiers as |label key|}}
                <option value='{{key}}' {{#if (eq key ../system.roll.tier)}}selected{{/if}}>{{localize label}}</option>
              {{/each}}
            </select>
          </div>
          <div class='grid-span-1'>
            <label class='resource-label'>{{localize "ASPECTSOFPOWER.SpellTier.baseMana"}}</label>
            <input type='text' value='{{#if spellBaseMana}}{{spellBaseMana}}{{else}}—{{/if}}' readonly disabled
                   title='Computed: tier_factor × grade_factor (grade = caster rank).' />
          </div>
          <div class='grid-span-1'>
            <label class='resource-label'>Grade (auto)</label>
            <input type='text' value='caster rank' readonly disabled
                   title='Spell grade auto-derives from the casting actor’s race rank — no per-skill setting needed.' />
          </div>
        </div>
        {{/if}}

        {{! ── Advanced (legacy escape hatches: manual multiplier override, statType, manual action weight). The new schema derives multiplier from rarity + alterations and weight from alterations + manual override; these fields stay for the rare designer-tweaked skill. ── }}
        <details class='advanced-section' style='margin-top:8px;'>
          <summary style='cursor:pointer;font-size:12px;color:#888;padding:4px 0;'>Advanced</summary>
          <div class='grid grid-4col' style='margin-top:6px;'>
            <div class='grid-span-1'>
              <label class='resource-label' title='Manual multiplier override — leave at 1 for the rarity ladder to drive damage.'>Manual Mult Override</label>
              <input type='number' name='system.roll.diceBonus' value='{{system.roll.diceBonus}}' min='0' step='0.01' />
            </div>
            <div class='grid-span-1'>
              <label class='resource-label' title='Manual action weight multiplier — leave at 1 for alteration-derived weight to drive cast time.'>Manual Weight Override</label>
              <input type='number' name='system.roll.actionWeightMultiplier' value='{{system.roll.actionWeightMultiplier}}' min='0.1' step='0.05' />
            </div>
            <div class='grid-span-1'>
              <label class='resource-label'>Stat Mode</label>
              <select name='system.roll.statType' data-dtype='String'>
                <option value="pure" {{#if (eq system.roll.statType "pure")}}selected{{/if}}>Pure</option>
                <option value="hybrid" {{#if (eq system.roll.statType "hybrid")}}selected{{/if}}>Hybrid</option>
              </select>
            </div>
            {{#if (eq system.roll.statType "hybrid")}}
              <div class='grid-span-1'>
                <label class='resource-label'>Secondary Ability</label>
                <select name='system.roll.secondaryAbility' data-dtype='String'>
                  <option value="vitality" {{#if (eq system.roll.secondaryAbility "vitality")}}selected{{/if}}>Vitality</option>
                  <option value="endurance" {{#if (eq system.roll.secondaryAbility "endurance")}}selected{{/if}}>Endurance</option>
                  <option value="strength" {{#if (eq system.roll.secondaryAbility "strength")}}selected{{/if}}>Strength</option>
                  <option value="dexterity" {{#if (eq system.roll.secondaryAbility "dexterity")}}selected{{/if}}>Dexterity</option>
                  <option value="toughness" {{#if (eq system.roll.secondaryAbility "toughness")}}selected{{/if}}>Toughness</option>
                  <option value="intelligence" {{#if (eq system.roll.secondaryAbility "intelligence")}}selected{{/if}}>Intelligence</option>
                  <option value="willpower" {{#if (eq system.roll.secondaryAbility "willpower")}}selected{{/if}}>Willpower</option>
                  <option value="wisdom" {{#if (eq system.roll.secondaryAbility "wisdom")}}selected{{/if}}>Wisdom</option>
                  <option value="perception" {{#if (eq system.roll.secondaryAbility "perception")}}selected{{/if}}>Perception</option>
                </select>
              </div>
              <div class='grid-span-1'>
                <label class='resource-label'>Primary Weight</label>
                <input type='number' name='system.roll.primaryWeight' value='{{system.roll.primaryWeight}}' min='0' max='1' step='0.05' />
              </div>
              <div class='grid-span-1'>
                <label class='resource-label'>Secondary Weight</label>
                <input type='number' name='system.roll.secondaryWeight' value='{{system.roll.secondaryWeight}}' min='0' max='1' step='0.05' />
              </div>
            {{/if}}
          </div>
        </details>
      </div>

      {{! ── Attack Tag Config ── }}
      {{#if (includes system.tags "attack")}}
      <div class='tag-config attack-config'>
        <label class='resource-label'>Target Defense</label>
        <select name='system.roll.targetDefense' data-dtype='String'>
          <option value="" {{#if (eq system.roll.targetDefense "")}}selected{{/if}}>(none)</option>
          <option value="melee" {{#if (eq system.roll.targetDefense "melee")}}selected{{/if}}>Melee</option>
          <option value="ranged" {{#if (eq system.roll.targetDefense "ranged")}}selected{{/if}}>Ranged</option>
          <option value="mind" {{#if (eq system.roll.targetDefense "mind")}}selected{{/if}}>Mind</option>
          <option value="soul" {{#if (eq system.roll.targetDefense "soul")}}selected{{/if}}>Soul</option>
        </select>
        <label class='resource-label' title="Optional second defense for 'single blow, two defenses' skills. Damage splits 50/50 across the two halves; toughness applies once.">Secondary Defense</label>
        <select name='system.roll.secondaryTargetDefense' data-dtype='String'>
          <option value="" {{#if (eq system.roll.secondaryTargetDefense "")}}selected{{/if}}>(none — single defense)</option>
          <option value="melee" {{#if (eq system.roll.secondaryTargetDefense "melee")}}selected{{/if}}>Melee</option>
          <option value="ranged" {{#if (eq system.roll.secondaryTargetDefense "ranged")}}selected{{/if}}>Ranged</option>
          <option value="mind" {{#if (eq system.roll.secondaryTargetDefense "mind")}}selected{{/if}}>Mind</option>
          <option value="soul" {{#if (eq system.roll.secondaryTargetDefense "soul")}}selected{{/if}}>Soul</option>
        </select>
        <label class='resource-label' title="Melee reach in feet. 0 = inherit from the wielded weapon (default 5ft). Set explicitly only when this skill has special reach (e.g. Lunge with extended reach).">Reach (0 = inherit weapon)</label>
        <input type='number' name='system.roll.reach' value='{{system.roll.reach}}' min='0' step='1' data-dtype='Number'>
        <label class='resource-label'>Damage Type</label>
        <select name='system.roll.damageType' data-dtype='String'>
          <option value="physical" {{#if (eq system.roll.damageType "physical")}}selected{{/if}}>Physical (Armor)</option>
          <option value="magical" {{#if (eq system.roll.damageType "magical")}}selected{{/if}}>Magical (Veil)</option>
        </select>
        <hr>
        <label class='resource-label checkbox-label'>
          <input type='checkbox' name='system.tagConfig.forcedMovement' {{#if system.tagConfig.forcedMovement}}checked{{/if}}>
          {{localize "ASPECTSOFPOWER.ForcedMovement.label"}}
        </label>
        {{#if system.tagConfig.forcedMovement}}
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.ForcedMovement.direction"}}</label>
        <select name='system.tagConfig.forcedMovementDir' data-dtype='String'>
          <option value="push" {{#if (eq system.tagConfig.forcedMovementDir "push")}}selected{{/if}}>{{localize "ASPECTSOFPOWER.ForcedMovement.push"}}</option>
          <option value="pull" {{#if (eq system.tagConfig.forcedMovementDir "pull")}}selected{{/if}}>{{localize "ASPECTSOFPOWER.ForcedMovement.pull"}}</option>
        </select>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.ForcedMovement.distance"}}</label>
        <input type='number' name='system.tagConfig.forcedMovementDist' value='{{system.tagConfig.forcedMovementDist}}' min='5' step='5'>
        {{/if}}
      </div>
      {{/if}}

      {{! ── Restoration Tag Config ── }}
      {{#if (includes system.tags "restoration")}}
      <div class='tag-config restoration-config'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.restorationTarget"}}</label>
        <select name='system.tagConfig.restorationTarget'>
          {{#each config.restorationTargets as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.tagConfig.restorationTarget)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.restorationResource"}}</label>
        <select name='system.tagConfig.restorationResource'>
          {{#each config.restorationResources as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.tagConfig.restorationResource)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
        {{#if (eq system.tagConfig.restorationResource "health")}}
        <label class='resource-label checkbox-label'>
          <input type='checkbox' name='system.tagConfig.restorationOverhealth'
                 {{#if system.tagConfig.restorationOverhealth}}checked{{/if}} />
          Overflow into Overhealth
        </label>
        {{/if}}
        {{#if (eq system.tagConfig.restorationResource "barrier")}}
        <label class='resource-label'>Barrier Multiplier</label>
        <input type='number' name='system.tagConfig.barrierMultiplier'
               value='{{system.tagConfig.barrierMultiplier}}' min='0' step='0.1' />
        <p class='hint'>Barrier HP = Mana spent &times; multiplier. Uses the skill's affinities.</p>
        {{/if}}
      </div>
      {{/if}}

      {{! ── Buff Tag Config ── }}
      {{#if (includes system.tags "buff")}}
      <div class='tag-config buff-config'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.buffAttributes"}}</label>
        {{#each buffAttributeGroups}}
          <div class='attribute-group'>
            <span class='group-label'>{{this.label}}</span>
            <div class='group-entries'>
              {{#each this.attributes}}
                <label class='attr-entry'>
                  <input type='checkbox' name='system.tagConfig.buffEntries'
                         value='{{this.key}}' {{#if this.checked}}checked{{/if}} />
                  {{this.label}}
                  {{#if this.checked}}
                    <span class='multiplier-label'>&times;</span>
                    <input type='number' class='attr-value' data-attr='{{this.key}}'
                           data-target='buff' value='{{this.value}}' min='0' step='0.1' />
                  {{/if}}
                </label>
              {{/each}}
            </div>
          </div>
        {{/each}}
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.tagConfig.buffStackable'
                 {{#if system.tagConfig.buffStackable}}checked{{/if}} />
          Stackable
        </label>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.duration"}}</label>
        <input type='number' name='system.tagConfig.buffDuration'
               value='{{system.tagConfig.buffDuration}}' min='0' step='1' />
        <label class='resource-label'>Target</label>
        <select name='system.tagConfig.buffTarget'>
          {{#each config.buffTargets as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.tagConfig.buffTarget)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
        {{#if (includes system.tags "movement")}}
        <label class='resource-label'>Movement Speed Buff (×)</label>
        <input type='number' name='system.tagConfig.movementSpeedBuff'
               value='{{system.tagConfig.movementSpeedBuff}}' min='0' step='0.1'
               title='Multiplier applied to the target&apos;s movement speed. 2 = double speed, 0.5 = half (slow).' />
        <label class='resource-label'>Movement Stamina Buff (×)</label>
        <input type='number' name='system.tagConfig.movementStaminaBuff'
               value='{{system.tagConfig.movementStaminaBuff}}' min='0' step='0.1'
               title='Multiplier on stamina cost per ft. 0.5 = efficient, 2 = exhausting.' />
        {{/if}}
        <label class='resource-label'>Aura Radius (ft)</label>
        <input type='number' name='system.tagConfig.auraRadius'
               value='{{system.tagConfig.auraRadius}}' min='0' step='1'
               title='Sustained AOE radius around the buffed actor. 0 = no aura. Ticks each round-start AND on entry. Auto-routes by Effect Type below.' />
        {{#if system.tagConfig.auraRadius}}
        <label class='resource-label'>Aura Effect Type</label>
        <select name='system.tagConfig.auraEffectType'>
          <option value='damage' {{#if (eq system.tagConfig.auraEffectType "damage")}}selected{{/if}}>Damage (apply-button)</option>
          <option value='heal' {{#if (eq system.tagConfig.auraEffectType "heal")}}selected{{/if}}>Heal (auto-apply)</option>
          <option value='stam' {{#if (eq system.tagConfig.auraEffectType "stam")}}selected{{/if}}>Stamina restore (auto-apply)</option>
        </select>
        <label class='resource-label'>Aura Targets</label>
        <select name='system.tagConfig.auraTargeting'>
          <option value='enemies' {{#if (eq system.tagConfig.auraTargeting "enemies")}}selected{{/if}}>Enemies</option>
          <option value='allies' {{#if (eq system.tagConfig.auraTargeting "allies")}}selected{{/if}}>Allies</option>
          <option value='all' {{#if (eq system.tagConfig.auraTargeting "all")}}selected{{/if}}>All</option>
        </select>
        <label class='resource-label'>Aura Scale (× roll)</label>
        <input type='number' name='system.tagConfig.auraScale'
               value='{{system.tagConfig.auraScale}}' min='0' max='5' step='0.05'
               title='Fraction of the cast roll applied per tick. 0.3 = 30% per round.' />
        {{#if (eq system.tagConfig.auraEffectType "damage")}}
        <label class='resource-label'>Aura Damage Type</label>
        <input type='text' name='system.tagConfig.auraDamageType'
               value='{{system.tagConfig.auraDamageType}}'
               title='Damage type (physical / lightning / fire / etc.). Magic-tagged skills route through veil; physical through armor.' />
        {{/if}}
        {{#if (eq system.tagConfig.auraEffectType "heal")}}
        <label class='resource-label'>Heal Resource</label>
        <select name='system.tagConfig.auraHealResource'>
          <option value='health' {{#if (eq system.tagConfig.auraHealResource "health")}}selected{{/if}}>Health</option>
          <option value='mana' {{#if (eq system.tagConfig.auraHealResource "mana")}}selected{{/if}}>Mana</option>
          <option value='stamina' {{#if (eq system.tagConfig.auraHealResource "stamina")}}selected{{/if}}>Stamina</option>
        </select>
        <label class='resource-label'>
          <input type='checkbox' name='system.tagConfig.auraHealOverhealth'
                 {{#if system.tagConfig.auraHealOverhealth}}checked{{/if}} />
          Overflow into Overhealth
        </label>
        {{/if}}
        {{/if}}
      </div>
      {{/if}}

      {{! ── Teleport Tag Config ── }}
      {{#if (includes system.tags "teleport")}}
      <div class='tag-config teleport-config'>
        <label class='resource-label'>Teleport Max Distance (ft, 0 = caster casting range)</label>
        <input type='number' name='system.tagConfig.teleportMaxDistance'
               value='{{system.tagConfig.teleportMaxDistance}}' min='0' step='5'
               title='Max teleport distance. 0 = inherit caster casting range (40 + Per.mod/10). Set > 0 to override (short Blink-style or fixed Mass Teleport). Sight always required at declare time.' />
      </div>
      {{/if}}

      {{! ── Leap Tag Config ── }}
      {{#if (includes system.tags "leap")}}
      <div class='tag-config leap-config'>
        <label class='resource-label'>Leap Max Distance (ft)</label>
        <input type='number' name='system.tagConfig.leapMaxDistance'
               value='{{system.tagConfig.leapMaxDistance}}' min='5' step='5'
               title='Max start-to-end distance for the leap arc.' />
        <label class='resource-label'>Leap Apex Height (ft)</label>
        <input type='number' name='system.tagConfig.leapApexFt'
               value='{{system.tagConfig.leapApexFt}}' min='0' step='1'
               title='Vault height. Walls in scene levels with elevation.top &lt; apex are bypassed; taller walls still block. Token stays at ground elevation throughout (AOEs and engagement evaluate the 2D path).' />
      </div>
      {{/if}}

      {{! ── Granted Tag Config (build-neutral activation time) ── }}
      {{#if (includes system.tags "granted")}}
      <div class='tag-config granted-config'>
        <label class='resource-label'>Min Activation Fraction (× round, at 0 ft)</label>
        <input type='number' name='system.tagConfig.grantedMinActivationFraction'
               value='{{system.tagConfig.grantedMinActivationFraction}}' min='0' max='2' step='0.01'
               title='Lower bound of cast wait for teleport/leap (very short hops). Set equal to Max to disable distance scaling.' />
        <label class='resource-label'>Max Activation Fraction (× round, at max range)</label>
        <input type='number' name='system.tagConfig.grantedActivationFraction'
               value='{{system.tagConfig.grantedActivationFraction}}' min='0' max='2' step='0.01'
               title='Cast wait at the skill&apos;s max teleport/leap distance. Wait lerps from min to this by distancePicked / maxDistance.' />
      </div>
      {{/if}}

      {{! ── Debuff Tag Config ── }}
      {{#if (includes system.tags "debuff")}}
      <div class='tag-config debuff-config'>
        {{#unless hasDebuffSubtype}}
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.Debuff.label"}}</label>
        <select name='system.tagConfig.debuffType'>
          {{#each config.debuffTypes as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.tagConfig.debuffType)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.debuffAttributes"}}</label>
        {{#each debuffAttributeGroups}}
          <div class='attribute-group'>
            <span class='group-label'>{{this.label}}</span>
            <div class='group-entries'>
              {{#each this.attributes}}
                <label class='attr-entry'>
                  <input type='checkbox' name='system.tagConfig.debuffEntries'
                         value='{{this.key}}' {{#if this.checked}}checked{{/if}} />
                  {{this.label}}
                  {{#if this.checked}}
                    <span class='multiplier-label'>&times;</span>
                    <input type='number' class='attr-value' data-attr='{{this.key}}'
                           data-target='debuff' value='{{this.value}}' min='0' step='0.1' />
                  {{/if}}
                </label>
              {{/each}}
            </div>
          </div>
        {{/each}}
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.tagConfig.debuffStackable'
                 {{#if system.tagConfig.debuffStackable}}checked{{/if}} />
          Stackable
        </label>
        <label class='resource-label'>Attack Scaling</label>
        <input type='number' name='system.tagConfig.debuffScaleWithAttack'
               value='{{system.tagConfig.debuffScaleWithAttack}}' min='0' max='1' step='0.05'
               title='0 = no scaling. 0.5 = debuff is 50% of attack damage.' />
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.tagConfig.debuffDirectional'
                 {{#if system.tagConfig.debuffDirectional}}checked{{/if}} />
          Omnidirectional DR
        </label>
        {{/unless}}
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.tagConfig.debuffDealsDamage'
                 {{#if system.tagConfig.debuffDealsDamage}}checked{{/if}} />
          {{localize "ASPECTSOFPOWER.TagConfig.debuffDealsDamage"}}
        </label>
        {{#if system.tagConfig.debuffDealsDamage}}
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.debuffDamageType"}}</label>
        <select name='system.tagConfig.debuffDamageType'>
          <option value='physical' {{#if (eq system.tagConfig.debuffDamageType "physical")}}selected{{/if}}>Physical (ignores Armor)</option>
          <option value='magical' {{#if (eq system.tagConfig.debuffDamageType "magical")}}selected{{/if}}>Magical (ignores Veil)</option>
        </select>
        <label class='resource-label'>DoT Scale</label>
        <input type='number' name='system.tagConfig.dotScale'
               value='{{system.tagConfig.dotScale}}' min='0' max='1' step='0.05'
               title='Per-tick DoT damage as a fraction of the attack roll. 0.1 = 10%, 0 = no DoT damage. Stacks of the same debuff sum.' />
        {{/if}}
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.duration"}}</label>
        <input type='number' name='system.tagConfig.debuffDuration'
               value='{{system.tagConfig.debuffDuration}}' min='0' step='1' />
      </div>
      {{/if}}

      {{! ── Repair Tag Config ── }}
      {{#if (includes system.tags "repair")}}
      <div class='tag-config repair-config'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.TagConfig.repairMaterials"}}</label>
        <div class='tag-checkboxes'>
          {{#each config.materialTypes as |label key|}}
            <label class='tag-checkbox'>
              <input type='checkbox' name='system.tagConfig.repairMaterials' value='{{key}}'
                {{#if (includes ../system.tagConfig.repairMaterials key)}}checked{{/if}} />
              {{localize label}}
            </label>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{! ── Mine Tag Config ── (only the summon side has capacity; Detonate has no config) }}
      {{#if (includes system.tags "mine")}}
      <div class='tag-config mine-config'>
        <label class='resource-label'>Mine Capacity</label>
        <input type='number' name='system.tagConfig.mineCapacity'
               value='{{system.tagConfig.mineCapacity}}' min='1' max='10' step='1'
               title='Max concurrent mines per caster placed by this summon. Excess placements FIFO-evict the oldest. The mine snapshots this skill\'s aoe + roll config at placement, so its explosion is this skill\'s identity.' />
      </div>
      {{/if}}

      {{! ── Shrapnel Tag Config ── }}
      {{#if (includes system.tags "shrapnel")}}
      <div class='tag-config shrapnel-config'>
        <label class='resource-label'>Defense Pool Multiplier</label>
        <input type='number' name='system.tagConfig.shrapnelMultiplier'
               value='{{system.tagConfig.shrapnelMultiplier}}' min='1.0' max='5.0' step='0.1'
               title='Multiplies the hit total when consuming defense pool. 1.5 = pool depletes 50% faster.' />
      </div>
      {{/if}}

      {{! ── Gather Tag Config ── }}
      {{#if (includes system.tags "gather")}}
      <div class='tag-config gather-config'>
        <label class='resource-label'>Material Type</label>
        <select name='system.tagConfig.gatherMaterial'>
          <option value="">(any)</option>
          {{#each @root.config.materialTypes as |label key|}}
            <option value="{{key}}" {{#if (eq key ../system.tagConfig.gatherMaterial)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
        <label class='resource-label'>Element</label>
        <select name='system.tagConfig.gatherElement'>
          <option value="">(none)</option>
          {{#each @root.config.craftElements as |elDef elKey|}}
            <option value="{{elKey}}" {{#if (eq elKey ../system.tagConfig.gatherElement)}}selected{{/if}}>
              {{localize elDef.label}}
            </option>
          {{/each}}
        </select>
      </div>
      {{/if}}

      {{! ── Craft Tag Config ── }}
      {{#if (includes system.tags "craft")}}
      <div class='tag-config craft-config'>
        <label class='resource-label'><strong>Allowed Item Types</strong></label>
        <p class='hint'>Check the item types this craft skill can produce. Empty = all types allowed.</p>
        <div class='craft-allowed-grid' style='display:grid;grid-template-columns:repeat(4,1fr);gap:4px;'>
          {{#each @root.config.craftItemTypes as |def key|}}
            <label style='display:flex;gap:4px;align-items:center;font-size:11px;'>
              <input type='checkbox' class='craft-allowed-type' data-type-key='{{key}}'
                     {{#if (includes ../system.craftAllowedTypes key)}}checked{{/if}} />
              <span title='{{def.category}}'>{{key}}</span>
            </label>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{! ── Sustain Tag Config ── }}
      {{#if (includes system.tags "sustain")}}
      <div class='tag-config sustain-config'>
        <label class='resource-label'>Upkeep Resource</label>
        <select name='system.tagConfig.sustainResource'>
          <option value="mana" {{#if (eq system.tagConfig.sustainResource "mana")}}selected{{/if}}>Mana</option>
          <option value="stamina" {{#if (eq system.tagConfig.sustainResource "stamina")}}selected{{/if}}>Stamina</option>
          <option value="health" {{#if (eq system.tagConfig.sustainResource "health")}}selected{{/if}}>Health</option>
        </select>
        <label class='resource-label'>Upkeep Cost (per round)</label>
        <input type='number' name='system.tagConfig.sustainCost'
               value='{{system.tagConfig.sustainCost}}' min='0' step='1' />
      </div>
      {{/if}}

      {{! ── Skill Chain Config ── }}
      {{#if system.tags.length}}
      <div class='tag-config chain-config'>
        <label class='resource-label' style='grid-column: 1 / -1;'>
          {{localize "ASPECTSOFPOWER.Chain.label"}}
        </label>

        {{#each chainedSkills}}
        <div class='chain-entry flexrow' data-chain-index='{{this.index}}'>
          <select class='chain-skill-select' data-chain-index='{{this.index}}'>
            <option value=''>-- Select Skill --</option>
            {{#each ../availableChainSkills}}
              <option value='{{this.id}}' {{#if (eq this.id ../skillId)}}selected{{/if}}>
                {{this.name}}
              </option>
            {{/each}}
          </select>
          <select class='chain-trigger-select' data-chain-index='{{this.index}}'>
            <option value='always' {{#if (eq this.trigger "always")}}selected{{/if}}>
              {{localize "ASPECTSOFPOWER.Chain.always"}}
            </option>
            <option value='on-hit' {{#if (eq this.trigger "on-hit")}}selected{{/if}}>
              {{localize "ASPECTSOFPOWER.Chain.onHit"}}
            </option>
            <option value='on-miss' {{#if (eq this.trigger "on-miss")}}selected{{/if}}>
              {{localize "ASPECTSOFPOWER.Chain.onMiss"}}
            </option>
          </select>
          <a class='chain-delete' data-chain-index='{{this.index}}' title='Remove'>
            <i class='fas fa-trash'></i>
          </a>
        </div>
        {{/each}}

        <a class='chain-add' title='{{localize "ASPECTSOFPOWER.Chain.add"}}'>
          <i class='fas fa-plus'></i> {{localize "ASPECTSOFPOWER.Chain.add"}}
        </a>
      </div>
      {{/if}}

    </div>

    {{! Attributes Tab }}
    <div class='tab attributes' data-group='primary' data-tab='attributes'>
      <div class='resource'>
        <label class='resource-label'>{{localize "ASPECTSOFPOWER.SkillCategory.label"}}</label>
        <select name='system.skillCategory'>
          {{#each config.skillCategories as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.skillCategory)}}selected{{/if}}>
              {{localize label}}
            </option>
          {{/each}}
        </select>
      </div>
      <div class='resource'>
        <label class='resource-label'>Skill Type</label>
        <select name='system.skillType'>
          <option value='Passive' {{#if (eq system.skillType "Passive")}}selected{{/if}}>Passive</option>
          <option value='Active' {{#if (eq system.skillType "Active")}}selected{{/if}}>Active</option>
          <option value='Reaction' {{#if (eq system.skillType "Reaction")}}selected{{/if}}>Reaction</option>
        </select>
      </div>
      {{#if (eq system.skillType "Reaction")}}
      <div class='resource'>
        <label class='resource-label'>Reaction Type</label>
        <select name='system.reactionType'>
          {{#each config.reactionTypes as |label key|}}
            <option value='{{key}}' {{#if (eq key ../system.reactionType)}}selected{{/if}}>{{localize label}}</option>
          {{/each}}
        </select>
      </div>
      {{/if}}
      {{! ── Skill Component Flags ── }}
      <div class='skill-components'>
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.requiresSight'
                 {{#if system.requiresSight}}checked{{/if}} />
          {{localize "ASPECTSOFPOWER.SkillComponent.requiresSight"}}
        </label>
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.vocalComponent'
                 {{#if system.vocalComponent}}checked{{/if}} />
          {{localize "ASPECTSOFPOWER.SkillComponent.vocalComponent"}}
        </label>
        <label class='resource-label dot-toggle'>
          <input type='checkbox' name='system.requiresHearing'
                 {{#if system.requiresHearing}}checked{{/if}} />
          {{localize "ASPECTSOFPOWER.SkillComponent.requiresHearing"}}
        </label>
      </div>

    </div>

    {{! ── Alterations editor ── }}
    <div class='form-section alterations-section'>
      <h3>{{localize "ASPECTSOFPOWER.Alteration.label"}}</h3>
      <p class='hint' style='font-size:11px;color:#888;margin:0 0 6px;'>
        Effective mult = rarity ({{lookup (lookup config.skillRarities system.rarity) 'mult'}})
        + Σ alteration dmgMod (floor 0). Cost = base × rarityMult × (1 + Σ costMod).
      </p>
      {{#each system.alterations as |alt idx|}}
        <div class='alteration-row' style='display:flex;gap:6px;align-items:center;margin-bottom:4px;'>
          <select name='system.alterations.{{idx}}.id' style='flex:1;'>
            <option value=''>— pick an alteration —</option>
            {{#each @root.config.alterationTags as |tag tagKey|}}
              <option value='{{tagKey}}' {{#if (eq alt.id tagKey)}}selected{{/if}}>
                {{localize tag.label}} (dmg {{tag.dmgMod}}, cost {{tag.costMod}})
              </option>
            {{/each}}
          </select>
          <button type='button' class='alteration-delete' data-index='{{idx}}' title='Remove'>×</button>
        </div>
      {{/each}}
      <button type='button' class='alteration-add'>+ Add Alteration</button>
    </div>
  </section>
</form>