<form class="{{cssClass}} flexcol" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    <div class="header-fields">
      <h1 class="charname">
        <input name="name" type="text" value="{{item.name}}" placeholder="Name"/>
      </h1>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">Description</a>
    <a class="item" data-tab="stats">Stats</a>
    <a class="item" data-tab="effects">Effects</a>
  </nav>

  <section class="sheet-body scrollable" data-scrollable>

    {{! Description Tab }}
    <div class="tab" data-group="primary" data-tab="description">
      <prose-mirror name="system.description" value="{{system.description}}" compact>
        {{{enrichedDescription}}}
      </prose-mirror>
    </div>

    {{! Stats Tab }}
    <div class="tab" data-group="primary" data-tab="stats">
      <div class="equip-section">
        <label class="profession-augment-toggle">
          <input type="checkbox" name="system.isProfessionAugment" {{checked system.isProfessionAugment}} />
          Profession Augment (only fits in profession augment slots)
        </label>
      </div>

      {{#if system.isProfessionAugment}}
      <div class="equip-section">
        <div class="equip-section-header flexrow">
          <h4>Craft Bonuses</h4>
          <a class="craft-bonus-add" title="Add Craft Bonus"><i class="fas fa-plus"></i></a>
        </div>
        <div class="craft-bonus-list">
          {{#each system.craftBonuses as |bonus idx|}}
            <div class="craft-bonus-row flexrow" data-index="{{idx}}">
              <select class="craft-bonus-type" data-index="{{idx}}">
                <option value="craftProgress" {{#if (eq bonus.type "craftProgress")}}selected{{/if}}>Craft Progress (flat)</option>
                <option value="craftSkillMod" {{#if (eq bonus.type "craftSkillMod")}}selected{{/if}}>Craft Skill Mod (flat)</option>
                <option value="d100Bonus" {{#if (eq bonus.type "d100Bonus")}}selected{{/if}}>d100 Bonus</option>
                <option value="gatherProgress" {{#if (eq bonus.type "gatherProgress")}}selected{{/if}}>Gather Progress (flat)</option>
                <option value="prepBonus" {{#if (eq bonus.type "prepBonus")}}selected{{/if}}>Preparation Bonus</option>
                <option value="rarityFloor" {{#if (eq bonus.type "rarityFloor")}}selected{{/if}}>Material Rarity Floor</option>
              </select>
              <input type="number" class="craft-bonus-value" data-index="{{idx}}" value="{{bonus.value}}" step="1" />
              <select class="craft-bonus-affinity" data-index="{{idx}}" title="Optional affinity filter">
                <option value="" {{#if (eq bonus.affinity "")}}selected{{/if}}>(any)</option>
                {{#each @root.config.craftElements as |elDef elKey|}}
                  <option value="{{elKey}}" {{#if (eq elKey ../bonus.affinity)}}selected{{/if}}>{{localize elDef.label}}</option>
                {{/each}}
              </select>
              <a class="craft-bonus-delete" data-index="{{idx}}" title="Remove"><i class="fas fa-trash"></i></a>
            </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      <div class="equip-section">
        <div class="equip-section-header flexrow">
          <h4>{{localize "ASPECTSOFPOWER.Equip.statBonuses"}}</h4>
          <a class="stat-bonus-add" title="Add Stat Bonus"><i class="fas fa-plus"></i></a>
        </div>
        <div class="stat-bonus-list">
          {{#each system.statBonuses as |bonus idx|}}
            <div class="stat-bonus-row flexrow" data-index="{{idx}}">
              <select class="stat-bonus-ability" data-index="{{idx}}">
                {{#each @root.config.abilities as |label aKey|}}
                  <option value="{{aKey}}" {{#if (eq aKey bonus.ability)}}selected{{/if}}>
                    {{localize label}}
                  </option>
                {{/each}}
              </select>
              <input type="number" class="stat-bonus-value" data-index="{{idx}}"
                     value="{{bonus.value}}" />
              <a class="stat-bonus-delete" data-index="{{idx}}" title="Remove">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          {{/each}}
        </div>
      </div>

      <div class="equip-section">
        <div class="equip-section-header flexrow">
          <h4>{{localize "ASPECTSOFPOWER.Augment.itemBonuses"}}</h4>
          <a class="item-bonus-add" title="Add Item Bonus"><i class="fas fa-plus"></i></a>
        </div>
        <div class="item-bonus-list">
          {{#each system.itemBonuses as |bonus idx|}}
            <div class="item-bonus-row flexrow" data-index="{{idx}}">
              <select class="item-bonus-field" data-index="{{idx}}">
                {{#each @root.itemBonusFields as |label fKey|}}
                  <option value="{{fKey}}" {{#if (eq fKey bonus.field)}}selected{{/if}}>
                    {{label}}
                  </option>
                {{/each}}
              </select>
              <input type="number" class="item-bonus-value" data-index="{{idx}}"
                     value="{{bonus.value}}" step="any" />
              <select class="item-bonus-mode" data-index="{{idx}}">
                <option value="percentage" {{#if (eq bonus.mode "percentage")}}selected{{/if}}>%</option>
                <option value="flat" {{#if (eq bonus.mode "flat")}}selected{{/if}}>Flat</option>
              </select>
              <a class="item-bonus-delete" data-index="{{idx}}" title="Remove">
                <i class="fas fa-trash"></i>
              </a>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{! Effects Tab }}
    <div class="tab effects" data-group="primary" data-tab="effects">
      {{> "systems/aspects-of-power/templates/item/parts/item-effects.hbs"}}
    </div>
  </section>
</form>
